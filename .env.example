# Local development defaults. Do not put real secrets in this file.
APP_DEFAULT_USER_EMAIL=local@example.com
APP_DEFAULT_USER_NAME="Local Student"

# Optional fallback key for local development only.
# Prefer entering your key in Settings so the UI exercises the provider settings flow.
OPENAI_API_KEY=
OPENAI_PROJECT_ID=

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
