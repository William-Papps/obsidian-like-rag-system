# Self-hosting auth settings.
AUTH_SESSION_SECRET=change-me-for-production
ALLOW_SELF_SIGNUP=true
OWNER_EMAIL=discordboteternal@gmail.com
HOSTED_AI_ENABLED=true
PERSONAL_API_KEY_SECRET=change-me-too

# Email verification.
# Preferred provider: Resend. In local development, you can leave these blank
# and use EMAIL_VERIFICATION_DEV_MODE=true to reveal the code in the auth UI.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_VERIFICATION_DEV_MODE=true
EMAIL_VERIFICATION_REQUIRED=false

# Optional local development fallback.
# Prefer user-entered keys in Settings for BYOK usage.
OPENAI_API_KEY=
OPENAI_PROJECT_ID=

# Optional hosted/shared-key configuration.
# If set, users on hosted AI plans can consume quota against this key.
HOSTED_OPENAI_API_KEY=
HOSTED_OPENAI_PROJECT_ID=

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
